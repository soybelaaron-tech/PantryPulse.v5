# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For local dev the defaults below are fine — update for production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001

# ─── Database ───────────────────────────────────────────────
# For Docker: use the service name below (already set in docker-compose.yml)
# For manual local setup: use mongodb://localhost:27017
MONGO_URL=mongodb://mongodb:27017
DB_NAME=pantry_pulse

# ─── AI / LLM ────────────────────────────────────────────────
# Get your key from https://app.emergentintegrations.com
EMERGENT_LLM_KEY=your_emergent_key_here

# ─── Auth ────────────────────────────────────────────────────
# Generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET=your_random_secret_here

# ─── Payments (optional) ─────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=your_stripe_secret_key_here

# ─── Seeded admin account (optional) ─────────────────────────
# Created automatically on first startup
ADMIN_EMAIL=admin@pantrypulse.com
ADMIN_PASSWORD=ChangeMe123!
